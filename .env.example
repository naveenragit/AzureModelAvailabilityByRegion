# Copy this file to `.env` and edit values as needed.
# All variables are optional — defaults work for public Azure.

# ---------- HTTP server ----------
HOST=127.0.0.1
PORT=8765
LOG_LEVEL=INFO

# ---------- Caching / HTTP ----------
# Server-side cache lifetime in seconds (per URL+params).
CACHE_TTL=300
# httpx client timeout in seconds.
HTTP_TIMEOUT=60

# ---------- Azure cloud ----------
# Public Azure (default). Override for sovereign clouds:
#   AzureUSGovernment: https://management.usgovcloudapi.net
#   AzureChinaCloud:   https://management.chinacloudapi.cn
ARM_ENDPOINT=https://management.azure.com
ARM_RESOURCE=https://management.azure.com

# ---------- API versions (rarely need to change) ----------
API_SUBSCRIPTIONS=2022-12-01
API_LOCATIONS=2022-12-01
API_COGSVC=2024-10-01
API_COGSVC_FALLBACK=2023-05-01
API_AML=2024-10-01-preview
